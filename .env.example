# PostgreSQL
POSTGRES_PASSWORD=changeme

# Session
SESSION_SECRET=generate-a-long-random-string

# Azure Entra ID (App Registration)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=https://yourdomain.com/auth/callback
AZURE_ALLOWED_ORIGINS=https://yourdomain.com,https://internal.yourdomain.local

# App
FRONTEND_URL=https://yourdomain.com
COOKIE_SECURE=true
PORT=3001

# Email (Graph API — requires Mail.Send application permission)
MAIL_FROM=noreply@yourdomain.com

# Storage
UPLOADS_DIR=/data/uploads

# Nginx internal port (used by host proxy)
APP_INTERNAL_PORT=8090

# Cloudflare Tunnel token (get from Cloudflare Zero Trust dashboard).
# Required only if you run the cloudflared service in docker-compose.yml.
CLOUDFLARE_TUNNEL_TOKEN=

# Encryption (Phase 1: foundation only — encryption is OFF by default).
# Master key wraps per-row data keys. Generate ONCE per deployment with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Losing this key after enabling encryption permanently destroys access
# to encrypted data. Back it up to a password manager / KMS before
# turning encryption on in encryption_settings.
RESOLVD_MASTER_KEY=

# Vendor outbound: Reply-To address used on emails sent to vendor contacts.
# Set this to the inbound mailbox the webhook adapter monitors so vendor
# replies land in the unmatched-email queue, not a person's inbox.
INBOUND_REPLY_TO=

# Inbound email webhook: shared secret required on POST /api/inbound/generic.
# When unset, the endpoint refuses all requests with 503. Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
INBOUND_WEBHOOK_SECRET=
