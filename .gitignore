.env
.env.*
!.env.example

# Node
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output
frontend/dist/

# Data / uploads / certs
data/
nginx/certbot/
nginx/certs/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
icon-preview.svg
docker-compose.override.yml
backups/

# DB backups / dumps
backup-*.sql
*.dump

# Internal-only roadmap (private)
.ROADMAP.md

# Claude Code workspace (local only)
.claude/

# Screenshot tooling (local-only — runner + plan + git hooks + root-level npm).
# scripts/build-with-version.sh is shipped; other contents stay local-only.
scripts/*
!scripts/build-with-version.sh
.githooks/
/package.json
/package-lock.json
.preview-last-sha
